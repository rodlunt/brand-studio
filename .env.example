# Brand Studio — Environment Configuration
# Copy this file to .env and fill in your values.
# You only need ONE provider — add whichever you have.

# ── Anthropic (Claude) ──
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── OpenAI (ChatGPT) ──
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Google (Gemini) ──
# Get a key at: https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=

# ── DeepSeek ──
# Get a key at: https://platform.deepseek.com/api_keys (~90% cheaper than Claude)
DEEPSEEK_API_KEY=

# ── Groq ──
# Get a key at: https://console.groq.com/keys (free tier, ultra-fast inference)
GROQ_API_KEY=

# Default provider: anthropic | openai | gemini | deepseek | groq
DEFAULT_PROVIDER=anthropic

# Server port (optional, defaults to 3000)
PORT=3000
