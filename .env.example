# Brand Studio — Environment Configuration
# Copy this file to .env and fill in your values.
# You only need ONE provider — add whichever you have.

# ── Anthropic (Claude API) ──
# Get a key at: https://console.anthropic.com/settings/keys
# Billing: https://console.anthropic.com/settings/billing
ANTHROPIC_API_KEY=

# ── OpenAI (ChatGPT) ──
# Get a key at: https://platform.openai.com/api-keys
# Billing: https://platform.openai.com/settings/organization/billing/overview
OPENAI_API_KEY=

# ── Google (Gemini) ──
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Claude Local (Max subscription) ──
# No key needed — uses your Claude Code session credentials.
# Just select "Claude (Local)" in the app's provider dropdown.
# Requires: npm install @anthropic-ai/sdk

# Default provider: anthropic | claude-local | openai | gemini
DEFAULT_PROVIDER=anthropic

# Server port (optional, defaults to 3000)
PORT=3000
